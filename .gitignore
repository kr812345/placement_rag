# Added by GitGuard (Node.js, Next.js, React, Python, FastAPI)
# Environment files contain secrets, API keys, and database credentials that should never be committed
.env
# Local environment overrides often contain developer-specific secrets
.env.local
# Environment-specific local files may contain sensitive overrides
.env.*.local
# Development environment secrets should not be shared
.env.development.local
# Production secrets must never be committed to version control
.env.production.local
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dist/
build/
out/
coverage/
.next/
# Test environment secrets should not be committed
.env.test.local
# Any environment file may contain sensitive configuration
*.env
venv/
.venv/
env/
ENV/
__pycache__/
*.py[cod]
*.so
.ipynb_checkpoints/
# SQLite database files may contain sensitive data
*.sqlite3
# Django default SQLite database should not be committed
db.sqlite3
*.db
# Secrets file should never be committed
secrets.json
# Local settings often contain secrets and should not be committed
local_settings.py
